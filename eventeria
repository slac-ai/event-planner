<script>
  // remove curtain from DOM after animation so it doesn't block interaction
  window.addEventListener('load', () => {
    setTimeout(() => {
      const c = document.querySelector('.curtain');
      if(c) c.style.display = 'none';
    }, 2400);
  });

  // scroll reveal
  const revealEls = document.querySelectorAll('.reveal');
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => { if(e.isIntersecting){ e.target.classList.add('in'); io.unobserve(e.target); } });
  }, { threshold: 0.15 });
  revealEls.forEach(el => io.observe(el));

  // mobile nav toggle placeholder (links collapse on small screens; CTA remains via sticky button)
</script>
